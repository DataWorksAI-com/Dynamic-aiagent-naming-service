# =============================================================================
# agentns — Environment Configuration Template
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For local dev:    leave everything as-is (defaults work)
# For production:   set AGENTNS_TLD, AGENTNS_NAMESPACE, and MONGODB_URI
#
# NEVER commit .env to git — it contains secrets.
# .env is already in .gitignore.
# =============================================================================


# ── Core identity ─────────────────────────────────────────────────────────────
# The TLD is your domain — all agents registered here get URNs under this domain.
# Example: urn:mycompany.com:my-app:emailer
#
AGENTNS_TLD=mycompany.com
AGENTNS_NAMESPACE=my-app


# ── Server ────────────────────────────────────────────────────────────────────
# Port agentns listens on.
# If deploying behind a reverse proxy (nginx/Caddy), keep this as 8200
# and expose 443 externally.
#
AGENTNS_PORT=8200


# ── Health sweep ──────────────────────────────────────────────────────────────
# How often (seconds) agentns probes all registered endpoints.
# Lower = faster failover detection. Higher = less network traffic.
# Recommended: 15-30 for production, 60 for low-traffic systems.
#
AGENTNS_HEALTH_INTERVAL=30


# ── Geocoding ─────────────────────────────────────────────────────────────────
# Enables automatic city -> lat/lon resolution via OpenStreetMap Nominatim.
# Set to "off" in air-gapped environments (built-in 120+ city table still works).
#
AGENTNS_GEOCODING=on


# ── MongoDB persistence ───────────────────────────────────────────────────────
# If empty, agentns runs in-memory (registry lost on restart).
# Recommended for production: use MongoDB Atlas or a dedicated MongoDB server.
#
# Atlas example:
#   MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
#
# Self-hosted example:
#   MONGODB_URI=mongodb://agentns:secret@mongo-host:27017/agentns?authSource=admin
#
# Local Docker MongoDB (docker compose --profile mongo up):
#   MONGODB_URI=mongodb://agentns:secret@mongo:27017/agentns?authSource=admin
#
MONGODB_URI=
MONGODB_DB=agentns


# ── Bundled MongoDB auth (only used with docker compose --profile mongo) ──────
# Only needed if you use the bundled mongo service in docker-compose.prod.yml.
# Ignored if MONGODB_URI points to Atlas or an external server.
#
MONGO_ROOT_USER=agentns
MONGO_ROOT_PASS=changeme


# ── Client SDK (set on agent/orchestrator machines, not the agentns server) ───
# Agents and orchestrators read this to find the agentns server.
# Set to the public IP or hostname of the server running agentns.
#
# Example: AGENTNS_URL=http://96.126.111.107:8200
#
AGENTNS_URL=http://localhost:8200
